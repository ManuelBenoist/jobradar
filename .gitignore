# --- Python ---
venv/
.venv/
__pycache__/
*.py[cod]
.env
*.egg-info
*.pyc

# --- dbt ---
transform/logs/
transform/target/
transform/dbt_packages/
transform/logs/
logs/

# --- Bases de données (DuckDB) ---
# On ignore les fichiers de base de données locaux
*.duckdb
*.duckdb.wal

# --- Données ---
# Très important : on n'envoie JAMAIS les données brutes sur GitHub
data/
# Payloads JSON bruts (dev local, miroir type couche raw/)
raw/**/*.json
ingestion/raw/**/*.json
ingestion/data/**/*.json

# --- OS & IDE ---
.DS_Store
.vscode/
.cursor/
/node_modules/

# --- Terraform ---
**/.terraform/
terraform.tfstate
terraform.tfvars
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
crash.log
*.zip

# --- LAMBDAS (Dépendances) ---
# On ignore tous les dossiers générés par 'pip install -t .'
src/lambda/adzuna/*
src/lambda/france_travail/*
src/lambda/jsearch/*
src/lambda/jooble/*

# Mais on force Git à garder nos scripts Python et fichiers de configuration !
!src/lambda/adzuna/*.py
!src/lambda/adzuna/requirements.txt
!src/lambda/france_travail/*.py
!src/lambda/france_travail/requirements.txt
!src/lambda/jsearch/*.py
!src/lambda/jsearch/requirements.txt
!src/lambda/jooble/*.py
!src/lambda/jooble/requirements.txt

# UI 
.streamlit
.streamlit/*
secrets.toml

# --- Lint/Tests ---
.pytest_cache/
.ruff_cache/
__pycache__/