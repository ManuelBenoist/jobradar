# =========================================================
# CONFIGURATION JOBRADAR - EXEMPLE
# Copier ce fichier vers .env et remplir les valeurs.
# =========================================================

# --- AWS & ATHENA ---
AWS_ACCESS_KEY_ID=votre_access_key
AWS_SECRET_ACCESS_KEY=votre_secret_key
AWS_REGION=eu-west-3
ATHENA_DATABASE=jobradar_db
ATHENA_S3_STAGING_DIR=s3://votre-bucket-athena-results/temp/

# --- API COLLECTORS (INGESTION) ---

# Adzuna (https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# France Travail (https://monespace.francetravail.fr/accueil/partenaire)
FT_CLIENT_ID=
FT_CLIENT_SECRET=

# JSearch via RapidAPI (https://rapidapi.com/letscrape-6bR7n6787/api/jsearch)
JSEARCH_API_KEY=

# Jooble (https://fr.jooble.org/api-about)
JOOBLE_API_KEY=

# --- SÉCURITÉ API & DASHBOARD ---
# Clé arbitraire pour sécuriser les échanges entre l'API et le Dashboard
INTERNAL_API_KEY=generer_une_cle_aleatoire_ici

# --- URLS (Optionnel pour dev local) ---
API_URL=http://localhost:8000/jobs