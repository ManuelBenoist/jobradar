# Copier vers .env et renseigner les valeurs (ne jamais committer .env).
# Documentation Adzuna : https://developer.adzuna.com/

# Adzuna API
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# France Travail — API officielle (OAuth2, espace développeur France Travail).
# Si vous utilisez un agrégateur ou un proxy tiers, adaptez les noms de variables côté code.
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
